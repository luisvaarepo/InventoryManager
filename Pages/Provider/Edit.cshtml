@page "{id:int}"
@model InventoryManagement.Pages.Provider.EditModel
@{
    ViewData["Title"] = "Edit Supplier";
}

<h1>Edit Supplier</h1>
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Supplier.Id" />
    <div class="form-group">
        <label asp-for="Supplier.Name"></label>
        <input asp-for="Supplier.Name" class="form-control" />
        <span asp-validation-for="Supplier.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Supplier.ContactInfo"></label>
        <input asp-for="Supplier.ContactInfo" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index">Back to List</a>
</form>
