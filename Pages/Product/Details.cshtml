@page "{id:int}"
@model InventoryManagement.Pages.Product.DetailsModel
@{
    ViewData["Title"] = "Product Details";
}

<h1>Product Details</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title mb-3">@Model.Product!.Name</h5>
        <dl class="row mb-0">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Product.Description) ? "-" : Model.Product.Description)</dd>

            <dt class="col-sm-3">Categories</dt>
            <dd class="col-sm-9">@(Model.Product.Categories.Count == 0 ? "-" : string.Join(", ", Model.Product.Categories.Select(c => c.Name)))</dd>

            <dt class="col-sm-3">Provider</dt>
            <dd class="col-sm-9">@Model.Product.Supplier?.Name</dd>

            <dt class="col-sm-3">UPC</dt>
            <dd class="col-sm-9">@Model.Product.UPC</dd>

            <dt class="col-sm-3">Cost</dt>
            <dd class="col-sm-9">@Model.Product.Cost</dd>

            <dt class="col-sm-3">Quantity</dt>
            <dd class="col-sm-9">@Model.Product.Quantity</dd>

            <dt class="col-sm-3">Low Stock Threshold</dt>
            <dd class="col-sm-9">@Model.Product.LowStockThreshold</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Product.IsDiscontinued)
                {
                    <span class="badge text-bg-secondary">Discontinued</span>
                }
                else if (Model.Product.IsLowStock)
                {
                    <span class="badge text-bg-warning">Low Stock</span>
                }
                else
                {
                    <span class="badge text-bg-success">Active</span>
                }
            </dd>

            <dt class="col-sm-3">Date Last Purchased</dt>
            <dd class="col-sm-9">@Model.Product.DateLastPurchased?.ToShortDateString()</dd>

            <dt class="col-sm-3">Estimated Time to Receive (weeks)</dt>
            <dd class="col-sm-9">@Model.Product.EstimatedTimeToReceiveWeeks</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-page="Index">Back to Products</a>
</div>
