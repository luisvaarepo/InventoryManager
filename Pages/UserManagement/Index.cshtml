@page
@model InventoryManagement.Pages.UserManagement.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<h1>User Management</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (!ViewContext.ModelState.IsValid)
{
    <div asp-validation-summary="All" class="alert alert-danger"></div>
}

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Update</th>
            @if (User.IsInRole("Manager"))
            {
                <th>Delete</th>
            }
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>
                <input form="user-@user.Id" type="email" name="email" value="@user.Email" class="form-control" required />
            </td>
            <td>
                <select form="user-@user.Id" name="role" class="form-select">
                    @foreach (var role in Model.AvailableRoles)
                    {
                        if (string.Equals(role, user.Role, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@role" selected>@role</option>
                        }
                        else
                        {
                            <option value="@role">@role</option>
                        }
                    }
                </select>
            </td>
            <td>
                <form id="user-@user.Id" method="post" asp-page-handler="Update">
                    <input type="hidden" name="userId" value="@user.Id" />
                    <button type="submit" class="btn btn-primary">Save</button>
                </form>
            </td>
            @if (User.IsInRole("Manager"))
            {
                <td>
                    @if (user.CanDelete)
                    {
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete @user.Email?');">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    }
                    else
                    {
                        <button type="button" class="btn btn-danger" disabled title="@user.DeleteBlockedReason">Delete</button>
                    }
                </td>
            }
        </tr>
    }
    </tbody>
</table>
