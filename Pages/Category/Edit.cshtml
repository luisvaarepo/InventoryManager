@page "{id:int}"
@model InventoryManagement.Pages.Category.EditModel
@{
    ViewData["Title"] = "Edit Category";
}

<h1>Edit Category</h1>
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Category.Id" />
    <div class="form-group">
        <label asp-for="Category.Name"></label>
        <input asp-for="Category.Name" class="form-control" />
        <span asp-validation-for="Category.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Category.Description"></label>
        <input asp-for="Category.Description" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index">Back to List</a>
</form>
