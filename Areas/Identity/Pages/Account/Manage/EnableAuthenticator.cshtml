@page
@model InventoryManagement.Areas.Identity.Pages.Account.Manage.EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator app";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}
<h3>@ViewData["Title"]</h3>

<div>
    <p>To use an authenticator app, follow these steps:</p>
    <ol class="list">
        <li>
            <p>
                Download an authenticator app such as Microsoft Authenticator, Google Authenticator, or Authy.
            </p>
        </li>
        <li>
            <p>Scan this QR code or enter this key <kbd>@Model.SharedKey</kbd> into your authenticator app.</p>
            <div class="alert alert-info">Use your authenticator app to scan this QR code.</div>
            <div id="qrCode" class="mb-3"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>
                Enter the verification code from your authenticator app.
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" />
                            <label asp-for="Input.Code"></label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">Verify</button>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        (() => {
            const qrCode = document.getElementById('qrCode');
            const qrCodeData = document.getElementById('qrCodeData');
            const qrCodeUri = qrCodeData?.getAttribute('data-url');

            if (!qrCode || !qrCodeUri) {
                return;
            }

            new QRCode(qrCode, {
                text: qrCodeUri,
                width: 200,
                height: 200
            });
        })();
    </script>
}
